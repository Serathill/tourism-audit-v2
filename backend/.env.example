# ═══════════════════════════════════════════════════════════
# Tourism Audit V2 — Backend Environment Variables
# Copy to .env and fill in values
# NEVER commit .env to git
# ═══════════════════════════════════════════════════════════

# ─── Google Gemini AI ──────────────────────────────────────
GOOGLE_API_KEY=
GEMINI_DEEP_RESEARCH_MODEL=deep-research-pro-preview-12-2025
GEMINI_FORMATTER_MODEL=gemini-3-pro-preview

# ─── Supabase ─────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_KEY=

# ─── Email (Resend) ──────────────────────────────────────
RESEND_API_KEY=
FROM_EMAIL=Digital Audit <no-reply@devidevs.com>

# ─── API Auth ────────────────────────────────────────────
BACKEND_API_KEY=

# ─── Meeting CTA ────────────────────────────────────────
MEETING_LINK=

# ─── CORS ────────────────────────────────────────────────
ALLOWED_ORIGINS=

# ─── Flask ───────────────────────────────────────────────
FLASK_ENV=production

# ─── Error Tracking ─────────────────────────────────────
SENTRY_DSN=

# ─── Pipeline Tuning ────────────────────────────────────
AUDIT_POLL_INTERVAL=30
AUDIT_MAX_WAIT_MINUTES=90
