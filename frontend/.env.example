# ═══════════════════════════════════════════════════════════
# Tourism Audit V2 — Environment Variables
# Copy to .env.local and fill in values
# NEVER commit .env.local to git
# ═══════════════════════════════════════════════════════════

# ─── Supabase ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Email (Resend) ──────────────────────────────────────
# Note: RESEND_API_KEY and FROM_EMAIL are backend-only (Render)
# FROM_EMAIL default: Audit Digital Turism <no-reply@audit-turism.ro>

# ─── reCAPTCHA v3 ────────────────────────────────────────
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5

# ─── Analytics ────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_FB_PIXEL_ID=
FB_CONVERSION_API_TOKEN=

# ─── Site Configuration ──────────────────────────────────
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_HONEYPOT_FIELD_NAME=_hp_website
BACKEND_API_URL=

# ─── Backend API Auth ────────────────────────────────────
BACKEND_API_KEY=

# ─── Rate Limiting (Upstash Redis) ───────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Error Tracking (Sentry) ─────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ─── Meeting CTA ─────────────────────────────────────────
MEETING_LINK=
